<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 自动停止(达标/卡住)时发通知，无人值守也能看到。Android13+ 需运行期授权。 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 题库未命中时的 AI 兜底：把题干+选项发第三方聚合平台 LuckyCola(通义千问中转，同竞品)取答案。
         普通网络权限，安装即授予，无需运行期申请。见 REQUIREMENTS 5.2 AI 兜底。 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 自动开启无障碍：普通App拿不到这个签名级权限，靠 adb 一次性授予
         (adb shell pm grant com.quizhelper.dumptool android.permission.WRITE_SECURE_SETTINGS，
          build.ps1 已自动带上)。授予后 App 可自己写 secure settings 开无障碍，免去手动进设置。
         tools:ignore 关掉 lint 对"保护级权限"的告警。 -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!-- 考试模式(错峰)的独立浮窗：无障碍一关，其 TYPE_ACCESSIBILITY_OVERLAY 浮窗就没了，
         故考试浮窗改用 TYPE_APPLICATION_OVERLAY(需下面权限，用户在系统设置里授予"显示在其他应用上层")。 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- ExamOverlayService 作前台服务运行，考试全程(可能几十分钟)保活、不被系统回收。 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DumpTool">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 服务改名/伪装：真正注册到系统的服务类是
             com.google.android.accessibility.selecttospeak.SelectToSpeakService
             （DumpAccessibilityService 的空壳子类），逻辑仍在父类。
             这样系统/dumpsys/目标App 读到的组件名看起来像 Google 自带"选择朗读"服务。
             android:label 也换成伪装文案，无障碍列表里显示"选择朗读"。 -->
        <service
            android:name="com.google.android.accessibility.selecttospeak.SelectToSpeakService"
            android:exported="false"
            android:label="@string/a11y_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 考试模式(错峰)的浮窗宿主：独立前台服务，托管 TYPE_APPLICATION_OVERLAY 浮窗，
             无障碍被关闭时仍存活(见 REQUIREMENTS 5.8)。foregroundServiceType 用 specialUse
             (安卓14+要求前台服务声明类型；本用途无对应标准类型，用 specialUse + 子类型说明)。 -->
        <service
            android:name=".ExamOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="exam_answer_overlay" />
        </service>

    </application>

</manifest>
